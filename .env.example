# ==========================================
# SUPABASE
# ==========================================
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_TABLE=contatos

# ==========================================
# Z-API (WhatsApp)
# ==========================================
ZAPI_INSTANCE_ID=your_instance_id_here
ZAPI_INSTANCE_TOKEN=your_instance_token_here
ZAPI_CLIENT_TOKEN=your_client_token_here

# ==========================================
# CONFIGURACOES
# ==========================================
# DRY_RUN=true  -> simula sem enviar mensagem real
# DRY_RUN=false -> envia mensagem de verdade
DRY_RUN=true
MAX_CONTACTS=3
